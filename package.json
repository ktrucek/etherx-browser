{
  "name": "etherx-browser",
  "version": "2.2.6",
  "description": "EtherX Browser — Web3-Native Browser with AI, SQLite, TLS 1.3, Ad-Blocker & Password Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-gpu --disable-software-rasterizer --disable-dev-shm-usage",
    "dev": "electron . --no-sandbox --disable-gpu --inspect=5858",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "author": {
    "name": "EtherX Team",
    "email": "info@kriptoentuzijasti.io",
    "url": "https://kriptoentuzijasti.io"
  },
  "homepage": "https://kriptoentuzijasti.io",
  "license": "MIT",
  "overrides": {
    "lzma-native": "8.0.6"
  },
  "build": {
    "appId": "io.kriptoentuzijasti.etherx",
    "productName": "EtherX Browser",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "EtherX Team <info@kriptoentuzijasti.io>"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ],
      "sign": null,
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.26.8",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.6.2",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "ethers": "^6.13.0",
    "i18next": "^23.11.5",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0"
  }
}
